{
  "name": "pionex-ai-kit",
  "version": "0.2.6",
  "description": "CLI for Pionex MCP: config init and credentials (writes ~/.pionex/config.toml)",
  "type": "module",
  "license": "MIT",
  "main": "dist/index.js",
  "bin": {
    "pionex-ai-kit": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "pionex",
    "cli",
    "mcp",
    "config"
  ],
  "devDependencies": {
    "@pionex-ai/core": "*",
    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  }
}
